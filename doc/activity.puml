@startuml
title Диаграмма активности: "Круг жизни" (Circle of Life)

start

:Муфаса правит Землями Прайда;
note right: Статус: Король

fork
  :Симба растет (Львенок);
fork again
  :Шрам вынашивает план;
end fork

:Шрам организует загон антилоп;
:Муфаса спасает Симбу;

if (Муфаса выживает?) then (нет)
  :Шрам предает Муфасу;
  :**Муфаса погибает**;
  note right #FFAAAA: Смерть Короля
  
  :Шрам захватывает трон;
  :Симба изгоняется;
  
  partition "Состояние: Изгнанник (Exile)" {
    :Симба живет в джунглях;
    :Принцип "Хакуна Матата";
    :Забывает свою ответственность;
  }
  
  partition "Состояние: Осознание (Awakening)" {
    :Рафики находит Симбу;
    :**Рафики показывает отражение**;
    note right: "Remember who you are"
    :Симба осознает судьбу;
    :Принимает ответственность;
  }
  
  :Симба возвращается в PrideLands;
  :Начинается битва со Шрамом;
  
  if (Симба побеждает?) then (да)
    :Шрам изгоняется / погибает;
    :**Симба восстанавливает трон**;
    note right #AAFFAA: Статус: Король
    :Земли Прайда процветают;
    stop
  else (нет)
    :Симба терпит поражение;
    :Система остается под властью Шрама;
    note right #FFAAAA: Плохая концовка
    stop
  endif
  
else (да)
  :Альтернативная история;
  note right: Муфаса выживает,\nно по сценарию так не бывает
  stop
endif

@enduml
